# Wattplot Controller v1 — secrets template
# ---------------------------------------
# Copy this file to `secrets.yaml` in the SAME directory as `wattplot.yaml`
# and replace every placeholder. `wattplot.yaml` references these via
# `!secret <name>` — do NOT commit your real `secrets.yaml`.

# Your home Wi-Fi SSID (2.4 GHz only — ESP32 does not support 5 GHz).
wifi_ssid: "YOUR_WIFI_SSID"

# Your home Wi-Fi password (WPA2 or WPA3).
wifi_password: "YOUR_WIFI_PASSWORD"

# Password for the ESPHome captive-portal fallback AP.
# Used when Wi-Fi is unreachable so you can still configure the device
# by connecting to the "Wattplot-Setup" SSID. 8+ characters.
ap_password: "CHANGE_ME_AT_LEAST_8_CHARS"

# AES-256 key for the native ESPHome API (Home Assistant integration).
# Generate with:  python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Must be base64, 32 raw bytes = 44 base64 chars.
api_encryption_key: "REPLACE_WITH_BASE64_44_CHAR_KEY"

# Password for OTA firmware updates. Used when you `esphome run` /
# `esphome upload` over the network. 8+ characters.
ota_password: "CHANGE_ME_AT_LEAST_8_CHARS"
